{
  "name": "goodfieldts",
  "version": "1.0.0",
  "description": "Godfield風カード対戦ゲーム エンジン（TypeScript実装）",
  "scripts": {
    "dev": "ts-node src/ui/cli/index.ts",
    "test": "jest",
    "build": "tsc",
    "gui": "vite src/ui/browser"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
